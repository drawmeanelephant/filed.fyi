---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
  BookMarked,
  CheckCircle,
  Clock,
  Fingerprint,
  FolderArchive,
  Gavel,
  Ghost,
  Lock,
  RadioTower,
  Skull,
  Tag,
  UserRound,
  Zap,
} from 'lucide-astro';

export async function getStaticPaths() {
  const entries = await getCollection('lorelog');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: entry }));
}

const entry = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const formattedDate = d.date.toLocaleDateString('en-us', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const sev = (s: string) => `lorelog-sev lorelog-sev--${s}`;
---

<StarlightPage frontmatter={{ title: d.title, description: d.description, template: 'doc' }}>
  <div class="ll-full not-content">
    <div class="ll-full__header">
      <div class="ll-full__header-top">
        {d.caseNumber && (
          <span class="ll-full__case">
            <Fingerprint size={12} aria-hidden="true" />
            {d.caseNumber}
          </span>
        )}
        <span class="ll-full__version">{d.versionLabel}</span>
        {d.classification !== 'public' && (
          <span class="ll-full__stamp">{d.classification.toUpperCase()}</span>
        )}
      </div>

      <div class="ll-full__status-bar">
        <span class={sev(d.severity)}>
          {d.severity.toUpperCase()}
        </span>
        <span class="ll-full__chip">
          <FolderArchive size={11} aria-hidden="true" />{d.disposition.toUpperCase()}
        </span>
        <span class="ll-full__chip">
          {d.resolution === 'resolved' && <CheckCircle size={11} aria-hidden="true" />}
          {d.resolution === 'pending' && <Clock size={11} aria-hidden="true" />}
          {d.resolution === 'unresolvable' && <Skull size={11} aria-hidden="true" />}
          {d.resolution === 'appealed' && <Gavel size={11} aria-hidden="true" />}
          {d.resolution === 'void' && <Ghost size={11} aria-hidden="true" />}
          {d.resolution.toUpperCase()}
        </span>
        {d.mascotRef && (
          <a href={`/docs/mascots/${d.mascotRef}`} class="ll-full__chip ll-full__chip--link">
            <RadioTower size={11} aria-hidden="true" />{d.mascotRef}
          </a>
        )}
      </div>

      <div class="ll-full__meta">
        <span><UserRound size={11} aria-hidden="true" />{d.filedBy ?? 'UNKNOWN CLERK'}</span>
        <span class="ll-sep">·</span>
        <span>{formattedDate}</span>
        {d.filedAt && <><span class="ll-sep">·</span><span>{d.filedAt}</span></>}
      </div>
    </div>

    <div class="ll-full__layout">
      <div class="ll-full__main">
        {d.redacted ? (
          <div class="ll-full__redacted-notice">
            <Lock size={18} aria-hidden="true" />
            <span>THIS RECORD HAS BEEN REDACTED BY ORDER OF THE FILING AUTHORITY.</span>
          </div>
        ) : (
          <div class="ll-full__prose"><Content /></div>
        )}
      </div>

      <aside class="ll-full__aside">
        <section class="ll-aside__section">
          <h3 class="ll-aside__section-title">Diagnostic</h3>
          <dl class="ll-aside__dl">
            <dt>Severity</dt><dd class={sev(d.severity)}>{d.severity}</dd>
            <dt>Disposition</dt><dd>{d.disposition}</dd>
            <dt>Resolution</dt><dd>{d.resolution}</dd>
            <dt>Class.</dt><dd>{d.classification}</dd>
            {d.escalationPath && <><dt>Escalation</dt><dd>{d.escalationPath}</dd></>}
          </dl>
        </section>

        {d.affectedSystems && d.affectedSystems.length > 0 && (
          <section class="ll-aside__section">
            <h3 class="ll-aside__section-title">Affected Systems</h3>
            <ul class="ll-aside__list ll-aside__list--systems">
              {d.affectedSystems.map((s: string) => (
                <li><Zap size={10} aria-hidden="true" />{s}</li>
              ))}
            </ul>
          </section>
        )}

        {d.relatedEntries && d.relatedEntries.length > 0 && (
          <section class="ll-aside__section">
            <h3 class="ll-aside__section-title">Related Entries</h3>
            <ul class="ll-aside__list ll-aside__list--related">
              {d.relatedEntries.map((slug: string) => (
                <li><BookMarked size={10} aria-hidden="true" /><a href={`/lorelog/${slug}`}>{slug}</a></li>
              ))}
            </ul>
          </section>
        )}

        {d.tags && d.tags.length > 0 && (
          <section class="ll-aside__section">
            <h3 class="ll-aside__section-title">Tags</h3>
            <div class="ll-aside__taglist">
              {d.tags.map((tag: string) => (
                <span class="ll-aside__tag"><Tag size={9} aria-hidden="true" />{tag}</span>
              ))}
            </div>
          </section>
        )}

        {d.notes && (
          <section class="ll-aside__section">
            <h3 class="ll-aside__section-title">Clerk Notes</h3>
            <p class="ll-aside__notes">{d.notes}</p>
          </section>
        )}
      </aside>
    </div>

    <a href="/lorelog" class="ll-full__back">← Return to Lorelog</a>
  </div>
</StarlightPage>

<style>
.ll-full {
  width: 100%;
}
.ll-full__header {
  font-family: var(--font-mono, 'Source Code Pro', monospace);
  background: var(--sl-color-bg-nav);
  border: 1px solid var(--sl-color-hairline);
  border-radius: 0.25rem;
  padding: 0.85rem 1rem;
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.ll-full__header-top {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.ll-full__case {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.65rem;
  color: var(--sl-color-gray-4);
}
.ll-full__version {
  font-size: 0.65rem;
  color: var(--sl-color-gray-4);
  margin-left: auto;
}
.ll-full__stamp {
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  color: #b87333;
  border: 1px solid color-mix(in srgb, #b87333 50%, transparent);
  padding: 0.1rem 0.3rem;
  border-radius: 1px;
}
.ll-full__status-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.4rem;
}
.ll-full__sev-badge {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 0.15rem 0.5rem;
  border-radius: 1px;
  border: 1px solid;
}
.ll-full__chip {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.09em;
  color: var(--sl-color-gray-3);
  border: 1px solid var(--sl-color-hairline);
  padding: 0.12rem 0.4rem;
  border-radius: 1px;
  text-decoration: none;
}
.ll-full__chip--link {
  color: var(--sl-color-text-accent);
}
.ll-full__chip--link:hover {
  color: var(--sl-color-text-accent-high);
}
.ll-full__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.62rem;
  color: var(--sl-color-gray-4);
}
.ll-full__meta span {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
}
.ll-sep {
  opacity: 0.4;
}
.ll-full__layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 240px;
  gap: 1.5rem;
  align-items: start;
}
@media (max-width: 900px) {
  .ll-full__layout {
    grid-template-columns: 1fr;
  }
}
.ll-full__main {
  min-width: 0;
}
.ll-full__prose {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--sl-color-text);
}
.ll-full__redacted-notice {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono, monospace);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  color: var(--sl-color-gray-4);
  border: 1px solid var(--sl-color-hairline);
  padding: 1rem;
  border-radius: 0.25rem;
  background: var(--sl-color-bg-nav);
}
.ll-full__aside {
  font-family: var(--font-mono, 'Source Code Pro', monospace);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: sticky;
  top: 1rem;
}
.ll-aside__section-title {
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sl-color-gray-5);
  border-bottom: 1px solid var(--sl-color-hairline);
  padding-bottom: 0.2rem;
  margin-bottom: 0.45rem;
}
.ll-aside__dl {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.25rem 0.75rem;
  font-size: 0.62rem;
}
.ll-aside__dl dt {
  color: var(--sl-color-gray-5);
}
.ll-aside__dl dd {
  color: var(--sl-color-gray-3);
}
.ll-aside__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  font-size: 0.62rem;
}
.ll-aside__list li {
  display: flex;
  align-items: center;
  gap: 0.3rem;
}
.ll-aside__list--systems li { color: #b87333; }
.ll-aside__list--related li { color: var(--sl-color-text-accent); }
.ll-aside__list--related li a { color: inherit; }
.ll-aside__taglist {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
}
.ll-aside__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.75rem;
  color: var(--sl-color-gray-4);
  border: 1px solid var(--sl-color-hairline);
  padding: 0.1rem 0.3rem;
  border-radius: 1px;
}
.ll-aside__notes {
  font-size: 0.62rem;
  color: var(--sl-color-gray-3);
  line-height: 1.6;
  margin: 0;
}
.ll-full__back {
  display: inline-flex;
  margin-top: 2rem;
  font-family: var(--font-mono, monospace);
  font-size: 0.65rem;
  color: var(--sl-color-text-accent);
  text-decoration: none;
  letter-spacing: 0.06em;
  border-bottom: 1px solid transparent;
  transition: border-color 150ms ease, color 150ms ease;
}
.ll-full__back:hover {
  color: var(--sl-color-text-accent-high);
  border-bottom-color: currentColor;
}
</style>
