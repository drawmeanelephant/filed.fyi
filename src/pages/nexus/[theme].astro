---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allMascots = await getCollection('mascots');
  const allLorelogs = await getCollection('lorelog');
  const allHaikus = await getCollection('haikus');
  const allLimericks = await getCollection('limericks');
  const allAphorisms = await getCollection('aphorisms');

  const allItems = [...allMascots, ...allLorelogs, ...allHaikus, ...allLimericks, ...allAphorisms];
  const tags = new Set<string>();

  allItems.forEach((item) => {
    if (item.data.tags) {
      const itemTags = Array.isArray(item.data.tags) ? item.data.tags : [item.data.tags];
    itemTags.forEach((tag: string) => {
      if (typeof tag === 'string' && tag.trim().length > 0 && tag.trim().length < 50 && !tag.includes('/')) {
        tags.add(tag.trim());
      }
    });
    }
  });

  return Array.from(tags).map((tag) => ({
    params: { theme: tag },
  }));
}

const { theme } = Astro.params;

const allMascots = await getCollection('mascots');
const allLorelogs = await getCollection('lorelog');
const allHaikus = await getCollection('haikus');
const allLimericks = await getCollection('limericks');
const allAphorisms = await getCollection('aphorisms');

const themeMascots = allMascots.filter(m => m.data.tags && (Array.isArray(m.data.tags) ? m.data.tags : [m.data.tags]).includes(theme));
const themeLorelogs = allLorelogs.filter(l => l.data.tags && (Array.isArray(l.data.tags) ? l.data.tags : [l.data.tags]).includes(theme));
const themeHaikus = allHaikus.filter(h => h.data.tags && (Array.isArray(h.data.tags) ? h.data.tags : [h.data.tags]).includes(theme));
const themeLimericks = allLimericks.filter(l => l.data.tags && (Array.isArray(l.data.tags) ? l.data.tags : [l.data.tags]).includes(theme));
const themeAphorisms = allAphorisms.filter(a => a.data.tags && (Array.isArray(a.data.tags) ? a.data.tags : [a.data.tags]).includes(theme));
---

<StarlightPage
  frontmatter={{
    title: `Nexus: ${theme}`,
    description: `All archival records, mascots, and poetry associated with the theme: ${theme}`,
    tableOfContents: false,
  }}
>

<p>
  <a href="/nexus" class="back-link">← Back to Thematic Nexus</a>
</p>

<div class="nexus-grid">
  {themeMascots.length > 0 && (
    <div class="nexus-section">
      <h2>Mascots</h2>
      <ul>
        {themeMascots.map(m => (
          <li><a href={`/${m.collection}/${m.id}`}>{m.data.title || m.data.displayName || m.id}</a></li>
        ))}
      </ul>
    </div>
  )}

  {themeLorelogs.length > 0 && (
    <div class="nexus-section">
      <h2>Lorelog Cases</h2>
      <ul>
        {themeLorelogs.map(l => (
          <li><a href={`/${l.collection}/${l.id}`}>{l.data.title || l.id}</a></li>
        ))}
      </ul>
    </div>
  )}

  {themeHaikus.length > 0 && (
    <div class="nexus-section">
      <h2>Haikus</h2>
      <ul>
        {themeHaikus.map(h => (
          <li><a href={`/${h.collection}/${h.id}`}>{h.data.title || h.id}</a></li>
        ))}
      </ul>
    </div>
  )}

  {themeLimericks.length > 0 && (
    <div class="nexus-section">
      <h2>Limericks</h2>
      <ul>
        {themeLimericks.map(l => (
          <li><a href={`/${l.collection}/${l.id}`}>{l.data.title || l.id}</a></li>
        ))}
      </ul>
    </div>
  )}

  {themeAphorisms.length > 0 && (
    <div class="nexus-section">
      <h2>Aphorisms</h2>
      <ul>
        {themeAphorisms.map(a => (
          <li><a href={`/${a.collection}/${a.id}`}>{a.data.title || a.id}</a></li>
        ))}
      </ul>
    </div>
  )}
</div>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-weight: 600;
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }
  .back-link:hover {
    text-decoration: underline;
  }
  .nexus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
  .nexus-section {
    background: var(--sl-color-bg-nav);
    padding: 1.5rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
  }
  .nexus-section h2 {
    margin-top: 0;
    font-size: var(--sl-text-h4);
    border-bottom: 1px solid var(--sl-color-hairline);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }
  .nexus-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nexus-section li {
    margin-bottom: 0.5rem;
  }
  .nexus-section a {
    color: var(--sl-color-white);
    text-decoration: none;
  }
  .nexus-section a:hover {
    color: var(--sl-color-text-accent);
    text-decoration: underline;
  }
</style>

</StarlightPage>
