---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import MascotRecord from '../../components/MascotRecord.astro';

const mascots = await getCollection('mascots');
const sorted = mascots.sort((a, b) => {
  const idA = a.data.mascotId ?? 9999;
  const idB = b.data.mascotId ?? 9999;
  return idA - idB;
});

const total = mascots.length;
const highCorruption = mascots.filter(m =>
  ['high', 'critical'].includes(m.data.corruptionLevel ?? '')
).length;
const canonical = mascots.filter(m => m.data.status === 'active').length;
---

<StarlightPage frontmatter={{ title: 'Mascot Registry' }}>
  <div class="mascots-page__meta">
    <span class="mascots-page__stat">entries: {total}</span>
    <span class="mascots-page__stat">canonical: {canonical}</span>
    <span class="mascots-page__stat mascots-page__bad">high-corruption: {highCorruption}</span>
  </div>

  <div class="mascots-page__grid">
    {sorted.map(mascot => (
      <MascotRecord mascot={mascot} isCardMode />
    ))}
  </div>
</StarlightPage>