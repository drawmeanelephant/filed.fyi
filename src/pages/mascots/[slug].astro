---
// src/pages/mascots/[slug].astro  (or wherever your detail route lives)
import { getCollection, getEntry } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/Page.astro'; // adjust if needed
import MascotRecord from '../../components/MascotRecord.astro';

export async function getStaticPaths() {
  const mascots = await getCollection('mascots');
  return mascots.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<!--
  If you use a Starlight layout override or MDX layout, inject
  MascotRecord via a <slot name="before-content"> or equivalent.
  The simplest drop-in for a custom page route:
-->

<MascotRecord mascot={entry} />

<article class="sl-markdown-content">
  <slot />
</article>