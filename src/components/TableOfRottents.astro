---
const { toc = [] } = Astro.props;

const filteredToc = toc
  .filter((item) => item.depth >= 2 && item.depth <= 3)
  .map((item) => ({
    ...item,
    text:
      item.text.length > 80
        ? item.text.slice(0, 77) + '…'
        : item.text
  }));
---

{filteredToc.length > 0 && (
  <aside
    class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto
           rounded-md border border-zinc-200/40
           bg-white/70 backdrop-blur
           p-3
           dark:border-zinc-800/60 dark:bg-zinc-950/40
           md:relative md:top-auto md:max-h-none md:overflow-visible"
  >
    <nav class="space-y-1 text-sm">
      {filteredToc.map((item) => (
        <a
          href={item.slug}
          class="block opacity-80 hover:opacity-100 hover:underline"
        >
          {item.text}
        </a>
      ))}
    </nav>
  </aside>
)}