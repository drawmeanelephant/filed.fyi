---
import * as Lucide from 'lucide-astro';

interface Props {
  icon: string;
  title: string;
  description?: string;
  tone?: "neutral" | "warning" | "critical" | "corrupted";
  size?: "normal" | "loud" | "dominant";
}

const { 
  icon, 
  title, 
  description, 
  tone = "neutral", 
  size = "normal" 
} = Astro.props;

/**
 * TONE MAPPING
 * Institutional, assertive color sets that define the "weight" of the component.
 */
const toneMap = {
  neutral: {
    base: "bg-zinc-900 border-zinc-800 text-zinc-400",
    icon: "text-zinc-700/50",
    accent: "bg-zinc-700"
  },
  warning: {
    base: "bg-stone-950 border-amber-900 text-amber-200/70",
    icon: "text-amber-800/30",
    accent: "bg-amber-800"
  },
  critical: {
    base: "bg-red-950/30 border-red-900 text-red-500",
    icon: "text-red-900/40",
    accent: "bg-red-600"
  },
  corrupted: {
    base: "bg-black border-indigo-900 text-fuchsia-500",
    icon: "text-indigo-900/40",
    accent: "bg-fuchsia-700"
  }
};

/**
 * SIZE MAPPING
 * Prioritizes the "dominant glyph" over standard UI scales.
 */
const sizeMap = {
  normal: {
    container: "p-4 gap-4 min-h-[180px] w-full",
    icon: "w-20 h-20",
    title: "text-xl",
    desc: "text-[10px]"
  },
  loud: {
    container: "p-6 gap-6 min-h-[280px] w-full",
    icon: "w-40 h-40",
    title: "text-3xl",
    desc: "text-xs"
  },
  dominant: {
    container: "p-8 gap-8 min-h-[380px] w-full",
    icon: "w-64 h-64",
    title: "text-5xl",
    desc: "text-sm"
  }
};

const t = toneMap[tone] || toneMap.neutral;
const s = sizeMap[size] || sizeMap.normal;

// Resolve icon component dynamically
const iconKey = icon.charAt(0).toUpperCase() + icon.slice(1);
const Icon = (Lucide as any)[iconKey] || (Lucide as any)[icon] || Lucide.Ghost;
---

<div class={`grave-block group relative border-2 flex flex-col font-mono uppercase transition-all duration-300 hover:brightness-110 ${t.base} ${s.container}`}>
  
  {/* Institutional Header Metadata */}
  <div class="flex justify-between items-start opacity-30 text-[9px] pointer-events-none select-none tracking-widest leading-none">
    <div class="flex items-center gap-1.5">
      <div class={`w-2 h-2 ${t.accent} ${tone === 'critical' ? 'animate-pulse' : ''}`}></div>
      <span>ARCHIVE_REF::{tone.toUpperCase()}</span>
    </div>
    <span class="opacity-40">NODE_{Math.random().toString(36).substring(7).toUpperCase()}</span>
  </div>

  {/* Dominant Glyph - The visual anchor */}
  <div class={`relative z-0 group-hover:rotate-1 transition-transform duration-1000 ease-in-out ${s.icon} ${t.icon}`}>
    <Icon class="w-full h-full stroke-[1.1] drop-shadow-lg" />
    
    {/* Corruption Effect Layer */}
    {tone === 'corrupted' && (
      <div class="absolute inset-0 opacity-20 blur-[2px] translate-x-1 translate-y-1 mix-blend-screen animate-pulse">
        <Icon class="w-full h-full stroke-1" />
      </div>
    )}
  </div>

  {/* Secondary Textual Content */}
  <div class="z-10 mt-auto flex flex-col">
    <h3 class={`font-black tracking-tighter leading-[0.8] break-all drop-shadow-md ${s.title}`}>
      {title}
    </h3>
    
    {description && (
      <p class={`mt-3 opacity-50 normal-case leading-snug max-w-[22ch] border-l-2 border-current pl-3 ${s.desc}`}>
        {description}
      </p>
    )}
  </div>

  {/* Structural Shadow Offset */}
  <div class="absolute -bottom-1.5 -right-1.5 inset-0 -z-10 bg-black opacity-50 pointer-events-none"></div>

  {/* "Broken" Masking Element */}
  <div class="absolute top-0 right-0 w-10 h-10 border-r border-t border-current opacity-10 pointer-events-none"></div>
</div>

<style>
  .grave-block {
    /* Intentional asymmetrical geometry */
    clip-path: polygon(0 0, 100% 0, 100% 92%, 94% 100%, 0 100%);
  }

  h3 {
    /* Institutional "crunchy" text look */
    text-shadow: 2px 2px 0px rgba(0,0,0,0.5);
  }
</style>
