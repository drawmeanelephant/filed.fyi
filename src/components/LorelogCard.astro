---
import type { CollectionEntry } from 'astro:content';
import {
  BookMarked,
  CheckCircle,
  ChevronDown,
  Clock,
  Fingerprint,
  FolderArchive,
  Gavel,
  Ghost,
  RadioTower,
  Skull,
  Tag,
  UserRound,
  Zap,
} from 'lucide-astro';

interface Props { entry: CollectionEntry<'lorelog'>; }
const { entry } = Astro.props;
const d = entry.data;
const expandId = `lorelog-${entry.id.replace(/[^a-z0-9]/gi, '-')}`;

const severityMeta: Record<string, { label: string; cls: string }> = {
  info: { label: 'INFO', cls: 'badge--info' },
  notice: { label: 'NOTICE', cls: 'badge--notice' },
  warning: { label: 'WARNING', cls: 'badge--warning' },
  critical: { label: 'CRITICAL', cls: 'badge--critical' },
  classified: { label: 'CLASSIFIED', cls: 'badge--classified' },
};
const dispositionMeta: Record<string, { label: string; cls: string }> = {
  filed: { label: 'FILED', cls: 'chip--filed' },
  archived: { label: 'ARCHIVED', cls: 'chip--archived' },
  contested: { label: 'CONTESTED', cls: 'chip--contested' },
  deferred: { label: 'DEFERRED', cls: 'chip--deferred' },
  expunged: { label: 'EXPUNGED', cls: 'chip--expunged' },
  redacted: { label: 'REDACTED', cls: 'chip--redacted' },
};
const resolutionMeta: Record<string, { label: string; cls: string }> = {
  pending: { label: 'PENDING', cls: 'chip--pending' },
  resolved: { label: 'RESOLVED', cls: 'chip--resolved' },
  unresolvable: { label: 'UNRESOLVABLE', cls: 'chip--unresolvable' },
  appealed: { label: 'APPEALED', cls: 'chip--appealed' },
  void: { label: 'VOID', cls: 'chip--void' },
};
const classStamp: Record<string, string> = {
  public: '', internal: 'INTERNAL', restricted: 'RESTRICTED', sealed: 'SEALED',
};

const sev = severityMeta[d.severity] ?? severityMeta.info;
const disp = dispositionMeta[d.disposition] ?? dispositionMeta.filed;
const res = resolutionMeta[d.resolution] ?? resolutionMeta.pending;
const stamp = classStamp[d.classification] ?? '';

const formattedDate = d.date.toLocaleDateString('en-us', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<article class="lorelog-card" x-data="{ open: false }">
  <div class="lorelog-card__header">
    <div class="lorelog-card__header-left">
      {d.caseNumber && (
        <span class="lorelog-card__case">
          <Fingerprint size={10} aria-hidden="true" />{d.caseNumber}
        </span>
      )}
      <span class={`badge ${sev.cls}`}>{sev.label}</span>
    </div>
    <div class="lorelog-card__header-right">
      <span class="lorelog-card__version">{d.versionLabel}</span>
      {stamp && <span class="lorelog-card__stamp">{stamp}</span>}
    </div>
  </div>

  <div class="lorelog-card__body">
    <h2 class="lorelog-card__title">
      {d.redacted ? <span class="lorelog-card__redacted">████████████████</span> : d.title}
    </h2>
    <p class="lorelog-card__description">
      {d.redacted ? '[CONTENT REDACTED BY ORDER OF THE FILING AUTHORITY]' : d.description}
    </p>
    <div class="lorelog-card__chips">
      <span class={`chip ${disp.cls}`}>
        <FolderArchive size={10} aria-hidden="true" />{disp.label}
      </span>
      <span class={`chip ${res.cls}`}>
        {d.resolution === 'resolved' && <CheckCircle size={10} aria-hidden="true" />}
        {d.resolution === 'pending' && <Clock size={10} aria-hidden="true" />}
        {d.resolution === 'unresolvable' && <Skull size={10} aria-hidden="true" />}
        {d.resolution === 'appealed' && <Gavel size={10} aria-hidden="true" />}
        {d.resolution === 'void' && <Ghost size={10} aria-hidden="true" />}
        {res.label}
      </span>
      {d.mascotRef && (
        <a href={`/docs/mascots/${d.mascotRef}`} class="chip chip--mascot">
          <RadioTower size={10} aria-hidden="true" />{d.mascotRef}
        </a>
      )}
    </div>
  </div>

  <button
    type="button"
    class="lorelog-card__toggle"
    @click="open = !open"
    :aria-expanded="open.toString()"
    aria-controls={expandId}
  >
    <span class="lorelog-card__toggle-meta">
      <span class="lorelog-card__meta-item"><UserRound size={10} aria-hidden="true" />{d.filedBy ?? 'UNKNOWN CLERK'}</span>
      <span class="lorelog-card__meta-item"><span class="lorelog-card__sep">·</span>{formattedDate}</span>
      {d.filedAt && <span class="lorelog-card__meta-item"><span class="lorelog-card__sep">·</span>{d.filedAt}</span>}
    </span>
    <span class="lorelog-card__toggle-icon" :class="open ? 'is-open' : ''">
      <ChevronDown size={12} aria-hidden="true" />
    </span>
  </button>

  <div
    id={expandId}
    x-show="open"
    x-transition:enter="transition-all duration-200 ease-out"
    x-transition:enter-start="opacity-0 max-h-0"
    x-transition:enter-end="opacity-100 max-h-9999px"
    x-transition:leave="transition-all duration-150 ease-in"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0 max-h-0"
    class="lorelog-card__expanded"
    style="display:none"
  >
    <div class="lorelog-card__expanded-inner">
      <section class="lorelog-card__section">
        <h3 class="lorelog-card__section-title">Diagnostic Record</h3>
        <dl class="lorelog-card__dl">
          <div><dt>Severity</dt><dd class={`lorelog-card__sev-text lorelog-card__sev-text--${d.severity}`}>{d.severity}</dd></div>
          <div><dt>Disposition</dt><dd>{d.disposition}</dd></div>
          <div><dt>Resolution</dt><dd>{d.resolution}</dd></div>
          <div><dt>Classification</dt><dd>{d.classification}</dd></div>
          {d.caseNumber && <div><dt>Case No.</dt><dd>{d.caseNumber}</dd></div>}
          {d.escalationPath && <div><dt>Escalation</dt><dd>{d.escalationPath}</dd></div>}
        </dl>
      </section>

      {d.affectedSystems && d.affectedSystems.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Affected Systems</h3>
          <ul class="lorelog-card__list lorelog-card__list--systems">
            {d.affectedSystems.map((sys: string) => (
              <li><Zap size={10} aria-hidden="true" class="lorelog-card__list-icon" />{sys}</li>
            ))}
          </ul>
        </section>
      )}

      {d.relatedEntries && d.relatedEntries.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Related Entries</h3>
          <ul class="lorelog-card__list lorelog-card__list--related">
            {d.relatedEntries.map((slug: string) => (
              <li>
                <BookMarked size={10} aria-hidden="true" class="lorelog-card__list-icon" />
                <a href={`/lorelog/${slug}`}>{slug}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {d.tags && d.tags.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Tags</h3>
          <div class="lorelog-card__taglist">
            {d.tags.map((tag: string) => (
              <span class="lorelog-card__tag"><Tag size={9} aria-hidden="true" />{tag}</span>
            ))}
          </div>
        </section>
      )}

      {d.notes && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Clerk Notes</h3>
          <p class="lorelog-card__notes">{d.notes}</p>
        </section>
      )}

      <a href={`/lorelog/${entry.id}`} class="lorelog-card__read-link">Open Full Record →</a>
    </div>
  </div>
</article>

<style>
.lorelog-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--sl-color-bg-nav);
  border: 1px solid var(--sl-color-hairline);
  border-radius: 0.25rem;
  overflow: hidden;
  font-family: var(--font-mono, 'Source Code Pro', monospace);
  transition: border-color 180ms ease, background 180ms ease;
}
.lorelog-card:hover {
  border-color: var(--sl-color-gray-5);
}
.lorelog-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.35rem 0.75rem;
  background: var(--sl-color-bg-sidebar);
  border-bottom: 1px solid var(--sl-color-hairline);
  gap: 0.5rem;
}
.lorelog-card__header-left,
.lorelog-card__header-right {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.lorelog-card__case {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: var(--sl-color-gray-4);
}
.lorelog-card__version {
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  color: var(--sl-color-gray-4);
}
.lorelog-card__stamp {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: #b87333;
  border: 1px solid color-mix(in srgb, #b87333 50%, transparent);
  padding: 0.1rem 0.3rem;
  border-radius: 1px;
  opacity: 0.95;
}
.lorelog-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 0.85rem 0.85rem 0.6rem;
  flex: 1;
}
.lorelog-card__title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--sl-color-white);
  line-height: 1.3;
  letter-spacing: 0.01em;
  margin: 0;
}
.lorelog-card__redacted {
  color: var(--sl-color-gray-5);
  letter-spacing: 0.02em;
}
.lorelog-card__description {
  font-size: 0.9rem;
  color: var(--sl-color-gray-3);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}
.lorelog-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  margin-top: 0.15rem;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  padding: 0.15rem 0.4rem;
  border-radius: 1px;
  border: 1px solid currentColor;
  opacity: 0.95;
  text-decoration: none;
}
.chip--filed { color: #4e8a6c; }
.chip--archived { color: var(--sl-color-gray-4); }
.chip--contested { color: #b87333; }
.chip--deferred { color: #6b7ab8; }
.chip--expunged { color: #8a3a3a; }
.chip--redacted {
  color: var(--sl-color-gray-5);
  background: color-mix(in srgb, var(--sl-color-gray-6) 25%, transparent);
}
.chip--pending { color: var(--sl-color-gray-3); }
.chip--resolved { color: #4e8a6c; }
.chip--unresolvable { color: #8a3a3a; }
.chip--appealed { color: #b87333; }
.chip--void { color: #6b4d8a; }
.chip--mascot {
  color: #4a7ab0;
  cursor: pointer;
}
.chip--mascot:hover {
  opacity: 1;
  color: #6b9dd0;
}
.badge {
  display: inline-flex;
  align-items: center;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  padding: 0.15rem 0.45rem;
  border-radius: 1px;
}
.badge--info {
  background: color-mix(in srgb, #3a7fa8 12%, transparent);
  color: #3a7fa8;
  border: 1px solid color-mix(in srgb, #3a7fa8 30%, transparent);
}
.badge--notice {
  background: color-mix(in srgb, #3a7a50 12%, transparent);
  color: #3a7a50;
  border: 1px solid color-mix(in srgb, #3a7a50 30%, transparent);
}
.badge--warning {
  background: color-mix(in srgb, #b87333 12%, transparent);
  color: #b87333;
  border: 1px solid color-mix(in srgb, #b87333 30%, transparent);
}
.badge--critical {
  background: color-mix(in srgb, #c04040 12%, transparent);
  color: #c04040;
  border: 1px solid color-mix(in srgb, #c04040 30%, transparent);
}
.badge--classified {
  background: color-mix(in srgb, #6b4d8a 12%, transparent);
  color: #6b4d8a;
  border: 1px solid color-mix(in srgb, #6b4d8a 30%, transparent);
}
.lorelog-card__toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0.45rem 0.85rem;
  background: var(--sl-color-bg-sidebar);
  border-top: 1px solid var(--sl-color-hairline);
  cursor: pointer;
  transition: background 180ms ease;
}
.lorelog-card__toggle:hover {
  background: color-mix(in srgb, var(--sl-color-bg-sidebar) 82%, var(--sl-color-white));
}
.lorelog-card__toggle-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.3rem 0.55rem;
  font-size: 0.75rem;
  color: var(--sl-color-gray-4);
  letter-spacing: 0.06em;
  text-align: left;
}
.lorelog-card__meta-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
}
.lorelog-card__sep {
  opacity: 0.4;
}
.lorelog-card__toggle-icon {
  color: var(--sl-color-gray-4);
  transition: transform 200ms ease;
  display: flex;
  flex-shrink: 0;
}
.lorelog-card__toggle-icon.is-open {
  transform: rotate(180deg);
}
.lorelog-card__expanded {
  border-top: 1px solid var(--sl-color-hairline);
  background: var(--sl-color-bg);
  overflow: hidden;
}
.lorelog-card__expanded-inner {
  padding: 0.85rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.lorelog-card__section-title {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--sl-color-gray-5);
  border-bottom: 1px solid var(--sl-color-hairline);
  padding-bottom: 0.25rem;
  margin-bottom: 0.5rem;
}
.lorelog-card__dl {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.4rem 1rem;
  font-size: 0.85rem;
}
.lorelog-card__dl dt {
  color: var(--sl-color-gray-5);
}
.lorelog-card__dl dd {
  color: var(--sl-color-gray-3);
}
.lorelog-card__sev-text--info { color: #3a7fa8; }
.lorelog-card__sev-text--notice { color: #3a7a50; }
.lorelog-card__sev-text--warning { color: #b87333; }
.lorelog-card__sev-text--critical { color: #c04040; }
.lorelog-card__sev-text--classified { color: #6b4d8a; }
.lorelog-card__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  font-size: 0.85rem;
  padding: 0;
  margin: 0;
}
.lorelog-card__list li {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}
.lorelog-card__list--systems li { color: #b87333; }
.lorelog-card__list--related li { color: #4a7ab0; }
.lorelog-card__list--related li a { color: inherit; }
.lorelog-card__list-icon {
  flex-shrink: 0;
  opacity: 0.7;
}
.lorelog-card__taglist {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}
.lorelog-card__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  color: var(--sl-color-gray-4);
  border: 1px solid var(--sl-color-hairline);
  padding: 0.1rem 0.35rem;
  border-radius: 1px;
}
.lorelog-card__notes {
  font-size: 0.85rem;
  color: var(--sl-color-gray-3);
  line-height: 1.6;
  margin: 0;
}
.lorelog-card__read-link {
  display: inline-flex;
  align-self: flex-start;
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  color: var(--sl-color-text-accent);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 150ms ease, color 150ms ease;
  margin-top: 0.25rem;
}
.lorelog-card__read-link:hover {
  color: var(--sl-color-text-accent-high);
  border-bottom-color: currentColor;
}
</style>
