---
import type { CollectionEntry } from 'astro:content';
import {
  BookMarked,
  CheckCircle,
  ChevronDown,
  Clock,
  Fingerprint,
  FolderArchive,
  Gavel,
  Ghost,
  RadioTower,
  Skull,
  Tag,
  UserRound,
  Zap,
} from 'lucide-astro';
import { mapLorelog } from '../lib/mappers/lorelog';

interface Props { entry: CollectionEntry<'lorelog'>; }
const { entry } = Astro.props;
const e = mapLorelog(entry);
const expandId = `lorelog-${entry.id.replace(/[^a-z0-9]/gi, '-')}`;
---

<article class="lorelog-card" x-data="{ open: false }">
  <div class="lorelog-card__header">
    <div class="lorelog-card__header-left">
      {e.caseNumber && (
        <span class="lorelog-card__case">
          <Fingerprint size={10} aria-hidden="true" />{e.caseNumber}
        </span>
      )}
      <span class={`badge ${e.severity.cls}`}>{e.severity.label}</span>
    </div>
    <div class="lorelog-card__header-right">
      <span class="lorelog-card__version">{e.versionLabel}</span>
      {e.stamp && <span class="lorelog-card__stamp">{e.stamp}</span>}
    </div>
  </div>

  <div class="lorelog-card__body">
    <h2 class="lorelog-card__title">
      {e.redacted ? <span class="lorelog-card__redacted">████████████████</span> : e.title}
    </h2>
    <p class="lorelog-card__description">
      {e.redacted ? '[CONTENT REDACTED BY ORDER OF THE FILING AUTHORITY]' : e.description}
    </p>
    <div class="lorelog-card__chips">
      <span class={`chip ${e.disposition.cls}`}>
        <FolderArchive size={10} aria-hidden="true" />{e.disposition.label}
      </span>
      <span class={`chip ${e.resolution.cls}`}>
        {e.resolution.key === 'resolved' && <CheckCircle size={10} aria-hidden="true" />}
        {e.resolution.key === 'pending' && <Clock size={10} aria-hidden="true" />}
        {e.resolution.key === 'unresolvable' && <Skull size={10} aria-hidden="true" />}
        {e.resolution.key === 'appealed' && <Gavel size={10} aria-hidden="true" />}
        {e.resolution.key === 'void' && <Ghost size={10} aria-hidden="true" />}
        {e.resolution.label}
      </span>
      {e.mascotRef && (
        <a href={`/${e.mascotRef}`} class="chip chip--mascot">
          <RadioTower size={10} aria-hidden="true" />{e.mascotRef}
        </a>
      )}
    </div>
  </div>

  <button
    type="button"
    class="lorelog-card__toggle"
    @click="open = !open"
    :aria-expanded="open.toString()"
    aria-controls={expandId}
  >
    <span class="lorelog-card__toggle-meta">
      <span class="lorelog-card__meta-item"><UserRound size={10} aria-hidden="true" />{e.filedBy ?? 'UNKNOWN CLERK'}</span>
      <span class="lorelog-card__meta-item"><span class="lorelog-card__sep">·</span>{e.date}</span>
      {e.filedAt && <span class="lorelog-card__meta-item"><span class="lorelog-card__sep">·</span>{e.filedAt}</span>}
    </span>
    <span class="lorelog-card__toggle-icon" :class="open ? 'is-open' : ''">
      <ChevronDown size={12} aria-hidden="true" />
    </span>
  </button>

  <div
    id={expandId}
    x-show="open"
    x-transition:enter="transition-all duration-200 ease-out"
    x-transition:enter-start="opacity-0 max-h-0"
    x-transition:enter-end="opacity-100 max-h-9999px"
    x-transition:leave="transition-all duration-150 ease-in"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0 max-h-0"
    class="lorelog-card__expanded"
    style="display:none"
  >
    <div class="lorelog-card__expanded-inner">
      <section class="lorelog-card__section">
        <h3 class="lorelog-card__section-title">Diagnostic Record</h3>
        <dl class="lorelog-card__dl">
          <div><dt>Severity</dt><dd class={`lorelog-card__sev-text lorelog-card__sev-text--${e.severity.key}`}>{e.severity.key}</dd></div>
          <div><dt>Disposition</dt><dd>{e.disposition.key}</dd></div>
          <div><dt>Resolution</dt><dd>{e.resolution.key}</dd></div>
          <div><dt>Classification</dt><dd>{e.stamp || '—'}</dd></div>
          {e.caseNumber && <div><dt>Case No.</dt><dd>{e.caseNumber}</dd></div>}
          {e.escalationPath && <div><dt>Escalation</dt><dd>{e.escalationPath}</dd></div>}
        </dl>
      </section>

      {e.affectedSystems && e.affectedSystems.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Affected Systems</h3>
          <ul class="lorelog-card__list lorelog-card__list--systems">
            {e.affectedSystems.map((sys: string) => (
              <li><Zap size={10} aria-hidden="true" class="lorelog-card__list-icon" />{sys}</li>
            ))}
          </ul>
        </section>
      )}

      {e.relatedEntries && e.relatedEntries.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Related Entries</h3>
          <ul class="lorelog-card__list lorelog-card__list--related">
            {e.relatedEntries.map((slug: string) => (
              <li>
                <BookMarked size={10} aria-hidden="true" class="lorelog-card__list-icon" />
                <a href={`/lorelog/${slug}`}>{slug}</a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {e.tags && e.tags.length > 0 && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Tags</h3>
          <div class="lorelog-card__taglist">
            {e.tags.map((tag: string) => (
              <span class="lorelog-card__tag"><Tag size={9} aria-hidden="true" />{tag}</span>
            ))}
          </div>
        </section>
      )}

      {e.notes && (
        <section class="lorelog-card__section">
          <h3 class="lorelog-card__section-title">Clerk Notes</h3>
          <p class="lorelog-card__notes">{e.notes}</p>
        </section>
      )}

      <a href={`/lorelog/${entry.id}`} class="lorelog-card__read-link">Open Full Record →</a>
    </div>
  </div>
</article>

<style>
.lorelog-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: var(--sl-color-bg-nav);
  border: 1px solid var(--sl-color-hairline);
  border-radius: 0.25rem;
  overflow: hidden;
  font-family: var(--font-mono, 'Source Code Pro', monospace);
  transition: border-color 180ms ease, background 180ms ease;
}
.lorelog-card:hover {
  border-color: var(--sl-color-gray-5);
}
.lorelog-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.35rem 0.75rem;
  background: var(--sl-color-bg-sidebar);
  border-bottom: 1px solid var(--sl-color-hairline);
  gap: 0.5rem;
}
.lorelog-card__header-left,
.lorelog-card__header-right {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.lorelog-card__case {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: var(--sl-color-gray-4);
}
.lorelog-card__version {
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  color: var(--sl-color-gray-4);
}
.lorelog-card__stamp {
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: #b87333;
  border: 1px solid color-mix(in srgb, #b87333 50%, transparent);
  padding: 0.1rem 0.3rem;
  border-radius: 1px;
  opacity: 0.95;
}
.lorelog-card__body {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 0.85rem 0.85rem 0.6rem;
  flex: 1;
}
.lorelog-card__title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--sl-color-white);
  line-height: 1.3;
  letter-spacing: 0.01em;
  margin: 0;
}
.lorelog-card__redacted {
  color: var(--sl-color-gray-5);
  letter-spacing: 0.02em;
}
.lorelog-card__description {
  font-size: 0.9rem;
  color: var(--sl-color-gray-3);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}
.lorelog-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  margin-top: 0.15rem;
}
.lorelog-card__toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0.45rem 0.85rem;
  background: var(--sl-color-bg-sidebar);
  border-top: 1px solid var(--sl-color-hairline);
  cursor: pointer;
  transition: background 180ms ease;
}
.lorelog-card__toggle:hover {
  background: color-mix(in srgb, var(--sl-color-bg-sidebar) 82%, var(--sl-color-white));
}
.lorelog-card__toggle-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.3rem 0.55rem;
  font-size: 0.75rem;
  color: var(--sl-color-gray-4);
  letter-spacing: 0.06em;
  text-align: left;
}
.lorelog-card__meta-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
}
.lorelog-card__sep {
  opacity: 0.4;
}
.lorelog-card__toggle-icon {
  color: var(--sl-color-gray-4);
  transition: transform 200ms ease;
  display: flex;
  flex-shrink: 0;
}
.lorelog-card__toggle-icon.is-open {
  transform: rotate(180deg);
}
.lorelog-card__expanded {
  border-top: 1px solid var(--sl-color-hairline);
  background: var(--sl-color-bg);
  overflow: hidden;
}
.lorelog-card__expanded-inner {
  padding: 0.85rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.lorelog-card__section-title {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--sl-color-gray-5);
  border-bottom: 1px solid var(--sl-color-hairline);
  padding-bottom: 0.25rem;
  margin-bottom: 0.5rem;
}
.lorelog-card__dl {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.4rem 1rem;
  font-size: 0.85rem;
}
.lorelog-card__dl dt {
  color: var(--sl-color-gray-5);
}
.lorelog-card__dl dd {
  color: var(--sl-color-gray-3);
}
.lorelog-card__sev-text--info { color: #3a7fa8; }
.lorelog-card__sev-text--notice { color: #3a7a50; }
.lorelog-card__sev-text--warning { color: #b87333; }
.lorelog-card__sev-text--critical { color: #c04040; }
.lorelog-card__sev-text--classified { color: #6b4d8a; }
.lorelog-card__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  font-size: 0.85rem;
  padding: 0;
  margin: 0;
}
.lorelog-card__list li {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}
.lorelog-card__list--systems li { color: #b87333; }
.lorelog-card__list--related li { color: #4a7ab0; }
.lorelog-card__list--related li a { color: inherit; }
.lorelog-card__list-icon {
  flex-shrink: 0;
  opacity: 0.7;
}
.lorelog-card__taglist {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
}
.lorelog-card__tag {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.75rem;
  letter-spacing: 0.06em;
  color: var(--sl-color-gray-4);
  border: 1px solid var(--sl-color-hairline);
  padding: 0.1rem 0.35rem;
  border-radius: 1px;
}
.lorelog-card__notes {
  font-size: 0.85rem;
  color: var(--sl-color-gray-3);
  line-height: 1.6;
  margin: 0;
}
.lorelog-card__read-link {
  display: inline-flex;
  align-self: flex-start;
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  color: var(--sl-color-text-accent);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 150ms ease, color 150ms ease;
  margin-top: 0.25rem;
}
.lorelog-card__read-link:hover {
  color: var(--sl-color-text-accent-high);
  border-bottom-color: currentColor;
}
</style>
