---
/**
 * MascotRecord.astro — unified mascot component
 * - Page mode (default): full dossier panel, registered as PageTitle override
 * - Card mode: compact grid card, used from mascots index page
 *
 * Props:
 *   entry   — Starlight PageTitle prop (CollectionEntry<'docs'> shape), OR
 *   mascot  — direct CollectionEntry<'mascots'> pass-through (card mode / legacy)
 *
 * isCardMode = !!mascot && !entry  (card on index, dossier on detail page)
 */
import Default from '@astrojs/starlight/components/PageTitle.astro';
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { mapMascot } from '../lib/mappers/mascot';

interface Props {
  // PageTitle override shape
  entry?: { id: string; collection: string; data: Record<string, unknown> };
  // Direct mascot pass-through (card mode)
  mascot?: CollectionEntry<'mascots'>;
  // Remaining Starlight PageTitle props
  [key: string]: unknown;
}

const { entry, mascot: mascotProp, ...rest } = Astro.props;

const isCardMode = !!mascotProp && !entry;
const isMascotPage = !isCardMode && entry?.collection === 'mascots';

// Resolve the mascot entry
let mascot: CollectionEntry<'mascots'> | null = mascotProp ?? null;
if (isMascotPage && !mascot) {
  mascot = await getEntry('mascots', entry!.id);
}

const m = mascot ? mapMascot(mascot) : null;
---

{/* ── NON-MASCOT PAGES: delegate to Starlight default ── */}
{!isCardMode && !isMascotPage && <Default {...rest}><slot /></Default>}

{/* ══════════════════════════════════════════════════════
    CARD MODE — compact grid tile (mascots index page)
    ══════════════════════════════════════════════════════ */}
{isCardMode && m && (
  <article class="mr-card">
    <div class="mr-card__header">
      <span class={m.statusClass}>{m.status.toUpperCase()}</span>
      <span class={m.renderClass}>{m.renderState.toUpperCase()}</span>
    </div>

    <div class="mr-card__image">
      {m.imageUrl
        ? <img src={m.imageUrl} alt={m.displayName} class="mr-card__img" loading="lazy" />
        : <span class="mr-card__emoji" aria-hidden="true">{m.emoji ?? '░'}</span>
      }
    </div>

    <div class="mr-card__body">
      <h2 class="mr-card__title">{m.displayName}</h2>
      <p class="mr-card__desc">{m.description ?? '—'}</p>
      <dl class="mr-card__stats">
        <div><dt>CORRUPT</dt><dd class={`mr-card__stat-val ${m.corruptClass}`}>{m.corruptionLevel}</dd></div>
        <div><dt>GLITCH</dt><dd class={`mr-card__stat-val ${m.glitchClass}`}>{m.glitchFrequency}</dd></div>
        <div><dt>RENDER</dt><dd class="mr-card__stat-val">{m.renderState}</dd></div>
      </dl>
    </div>

    <div class="mr-card__footer">
      <span class={m.corruptClass}>CORRUPT:{m.corruptionLevel.toUpperCase()}</span>
      <span class={m.glitchClass}>GLITCH:{m.glitchFrequency.toUpperCase()}</span>
    </div>
  </article>
)}

{/* ══════════════════════════════════════════════════════
    DOSSIER MODE — full panel on mascot detail pages
    ══════════════════════════════════════════════════════ */}
{!isCardMode && m && (
  <aside class="mascot-record" aria-label="Mascot Dossier">

    <div class="mascot-record__header">
      <div class="mascot-record__header-left">
        {m.mascotId && (
          <span class="mascot-record__id">◈ {String(m.mascotId).padStart(3, '0')}</span>
        )}
        <span class={m.statusClass}>{m.status.toUpperCase()}</span>
        <span class={m.renderClass}>{m.renderState.toUpperCase()}</span>
      </div>
      <div class="mascot-record__header-right">
        <span class={m.corruptClass}>CORRUPT:{m.corruptionLevel.toUpperCase()}</span>
        <span class={m.glitchClass}>GLITCH:{m.glitchFrequency.toUpperCase()}</span>
        {m.breedingProgram && <span class="mascot-record__stamp">BRED</span>}
      </div>
    </div>

    <div class="mascot-record__avatar-band">
      {m.imageUrl
        ? <img src={m.imageUrl} alt={m.displayName} class="mascot-record__avatar-img" loading="lazy" decoding="async" />
        : m.emoji
          ? <span class="mascot-record__avatar-emoji" aria-hidden="true">{m.emoji}</span>
          : null
      }
      <div class="mascot-record__avatar-meta">
        <p class="mascot-record__name">{m.displayName}</p>
        {m.slogan && <p class="mascot-record__slogan">"{m.slogan}"</p>}
      </div>
    </div>

    <div class="mascot-record__grid-section">
      <p class="mascot-record__section-label">Diagnostic Record</p>
      <dl class="mascot-record__dl">
        <div><dt>Slug</dt><dd class="mascot-record__val--muted">{m.slug ?? '—'}</dd></div>
        <div><dt>Role</dt><dd>{m.role ?? '—'}</dd></div>
        <div><dt>Function</dt><dd>{m.mascotFunction ?? '—'}</dd></div>
        <div><dt>Tone</dt><dd class="mascot-record__val--accent">{m.emotionalTone ?? '—'}</dd></div>
        <div><dt>Rot Affinity</dt>
          <dd class={m.rotAffinity ? 'mascot-record__val--warn' : 'mascot-record__val--null'}>
            {m.rotAffinity ?? 'null'}
          </dd>
        </div>
        <div><dt>Integrity</dt><dd class="mascot-record__val--ok">{m.emotionalIntegrity ?? '—'}</dd></div>
        {m.emotionalIntBuffer != null && (
          <div><dt>Int. Buffer</dt>
            <dd class="mascot-record__val--purple">{m.emotionalIntBuffer}</dd>
          </div>
        )}
        <div><dt>System</dt>
          <dd class={m.systemAffiliation ? '' : 'mascot-record__val--null'}>
            {m.systemAffiliation ?? 'unaffiliated'}
          </dd>
        </div>
        <div><dt>Origin</dt><dd>{m.origin ?? '—'}</dd></div>
        <div><dt>Manifested</dt><dd class="mascot-record__val--muted">{m.manifestedBy ?? '—'}</dd></div>
        <div><dt>Last Good</dt><dd class="mascot-record__val--ok">{m.lastKnownGoodState ?? '—'}</dd></div>
        <div><dt>Version</dt><dd class="mascot-record__val--muted">{m.version ? `v${m.version}` : '—'}</dd></div>
        <div><dt>Author</dt><dd>{m.author ?? '—'}</dd></div>
        <div><dt>Date</dt><dd class="mascot-record__val--muted">{m.date ?? '—'}</dd></div>
      </dl>
    </div>

    <div class="mascot-record__chips-section" aria-label="Classification chips">
      {(m.tags.length > 0 ? m.tags : ['—']).map((t: string) => (
        <span class="chip chip--archived">{t}</span>
      ))}
      <span class="chip chip--notice" title={m.breedingProgram ?? ''}>
        {m.breedingProgram ?? 'NO PROGRAM'}
      </span>
    </div>

    <div class="mascot-record__sections">
      {m.description && (
        <details class="mascot-record__expand">
          <summary class="mascot-record__expand-toggle">
            ░ Description
            <span class="mascot-record__expand-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="mascot-record__expand-body">
            <p class="mascot-record__prose">{m.description}</p>
          </div>
        </details>
      )}
      {m.knownFailures.length > 0 && (
        <details class="mascot-record__expand">
          <summary class="mascot-record__expand-toggle">
            ░ Known Failures
            <span class="mascot-record__expand-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="mascot-record__expand-body">
            <ul class="mascot-record__list mascot-record__list--failures">
              {m.knownFailures.map((f: string) => <li>{f}</li>)}
            </ul>
          </div>
        </details>
      )}
      {m.ceremonialTasks.length > 0 && (
        <details class="mascot-record__expand">
          <summary class="mascot-record__expand-toggle">
            ░ Ceremonial Tasks
            <span class="mascot-record__expand-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="mascot-record__expand-body">
            <ul class="mascot-record__list mascot-record__list--tasks">
              {m.ceremonialTasks.map((t: string) => <li>{t}</li>)}
            </ul>
          </div>
        </details>
      )}
      {m.haikuLog.length > 0 && (
        <details class="mascot-record__expand">
          <summary class="mascot-record__expand-toggle">
            ░ Haiku Log
            <span class="mascot-record__expand-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="mascot-record__expand-body">
            {m.haikuLog.map((h: string) => (
              <blockquote class="mascot-record__haiku">{h.trim()}</blockquote>
            ))}
          </div>
        </details>
      )}
      {m.notes && (
        <details class="mascot-record__expand">
          <summary class="mascot-record__expand-toggle">
            ░ Notes / Addendum
            <span class="mascot-record__expand-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="mascot-record__expand-body">
            <p class="mascot-record__prose">{m.notes}</p>
          </div>
        </details>
      )}
    </div>

  </aside>
)}