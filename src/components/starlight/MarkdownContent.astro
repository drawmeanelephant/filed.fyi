---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import { render } from 'astro:content';
import { getMatchingPoetry, getPoemId } from '../../lib/poetry-matcher';

const entry = Astro.locals?.starlightRoute?.entry;
const { matchingHaikus, matchingLimericks, matchingAphorisms, isMascot, isLorelog } = await getMatchingPoetry(entry);
---

<Default {...Astro.props}>
  <slot />

  {isMascot && (
    <>
      {matchingAphorisms.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-aphorisms">Aphorisms</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingAphorisms.map(async (aphorism) => {
              const { Content } = await render(aphorism);
              return (
                <div id={getPoemId(aphorism)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingHaikus.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-haikus">Haiku Log</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingHaikus.map(async (haiku) => {
              const { Content } = await render(haiku);
              return (
                <div id={getPoemId(haiku)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingLimericks.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-limericks">Limerick Log</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingLimericks.map(async (limerick) => {
              const { Content } = await render(limerick);
              return (
                <div id={getPoemId(limerick)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}
    </>
  )}

  {isLorelog && (
    <>
      {matchingHaikus.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-haikus">Related Haikus</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingHaikus.map(async (haiku) => {
              const { Content } = await render(haiku);
              return (
                <div id={getPoemId(haiku)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingLimericks.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-limericks">Related Limericks</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingLimericks.map(async (limerick) => {
              const { Content } = await render(limerick);
              return (
                <div id={getPoemId(limerick)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}
    </>
  )}

  {!isMascot && !isLorelog && (matchingAphorisms.length > 0 || matchingHaikus.length > 0 || matchingLimericks.length > 0) && (
    <div class="unmatched-poetry-section" style="margin-top: 4rem;">
      <h2 id="non-compliance-verses">Non-Compliance Verses</h2>
      
      {matchingAphorisms.length > 0 && (
        <div class="poetry-group" style="margin-top: 2rem;">
          <h3 id="unmatched-aphorisms">Aphorisms</h3>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingAphorisms.map(async (aphorism) => {
              const { Content } = await render(aphorism);
              return (
                <div id={getPoemId(aphorism)} class="broside" style="margin-bottom: 2rem; padding: 1.5rem; max-width: 100%;">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingHaikus.length > 0 && (
        <div class="poetry-group" style="margin-top: 2rem;">
          <h3 id="unmatched-haikus">Haikus</h3>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingHaikus.map(async (haiku) => {
              const { Content } = await render(haiku);
              return (
                <div id={getPoemId(haiku)} class="broside" style="margin-bottom: 2rem; padding: 1.5rem; max-width: 100%;">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingLimericks.length > 0 && (
        <div class="poetry-group" style="margin-top: 2rem;">
          <h3 id="unmatched-limericks">Limericks</h3>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingLimericks.map(async (limerick) => {
              const { Content } = await render(limerick);
              return (
                <div id={getPoemId(limerick)} class="broside" style="margin-bottom: 2rem; padding: 1.5rem; max-width: 100%;">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}
    </div>
  )}
</Default>
