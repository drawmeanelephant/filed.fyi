---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import { render } from 'astro:content';
import { getMatchingPoetry, getPoemId } from '../../lib/poetry-matcher';

const entry = Astro.locals?.starlightRoute?.entry;
const {
  matchingHaikus,
  matchingLimericks,
  matchingAphorisms,
  isMascot,
} = await getMatchingPoetry(entry);

// Lorelogs, references, guides, posts, etc. all share the "related" presentation.
// Mascots keep their own "Haiku Log / Limerick Log / Aphorisms" labels.
const showRelatedBlock = !isMascot && (matchingAphorisms.length > 0 || matchingHaikus.length > 0 || matchingLimericks.length > 0);
---

<Default {...Astro.props}>
  <slot />

  {isMascot && (
    <>
      {matchingAphorisms.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-aphorisms">Aphorisms</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingAphorisms.map(async (aphorism) => {
              const { Content } = await render(aphorism);
              return (
                <div id={getPoemId(aphorism)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingHaikus.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-haikus">Haiku Log</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingHaikus.map(async (haiku) => {
              const { Content } = await render(haiku);
              return (
                <div id={getPoemId(haiku)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingLimericks.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-limericks">Limerick Log</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingLimericks.map(async (limerick) => {
              const { Content } = await render(limerick);
              return (
                <div id={getPoemId(limerick)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}
    </>
  )}

  {showRelatedBlock && (
    <>
      {matchingAphorisms.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-aphorisms">Related Aphorisms</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingAphorisms.map(async (aphorism) => {
              const { Content } = await render(aphorism);
              return (
                <div id={getPoemId(aphorism)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingHaikus.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-haikus">Related Haikus</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingHaikus.map(async (haiku) => {
              const { Content } = await render(haiku);
              return (
                <div id={getPoemId(haiku)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}

      {matchingLimericks.length > 0 && (
        <div class="inline-poetry-section" style="margin-top: 3rem;">
          <h2 id="inline-limericks">Related Limericks</h2>
          <div class="poetry-masonry-yard">
            {await Promise.all(matchingLimericks.map(async (limerick) => {
              const { Content } = await render(limerick);
              return (
                <div id={getPoemId(limerick)} class="inline-poem-wrapper">
                  <Content />
                </div>
              );
            }))}
          </div>
        </div>
      )}
    </>
  )}
</Default>
