{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["./src/components/*"],
      "@/starlight/*": ["./node_modules/@astrojs/starlight/components/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}